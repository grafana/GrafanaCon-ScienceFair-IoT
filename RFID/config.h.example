// Copy this file to config.h and fill in your credentials:
//   cp config.h.example config.h

// Set your local WiFi username and password. Please use a 2.4GHz access point
#define WIFI_SSID     ""
#define WIFI_PASSWORD ""

// For more information on where to get these values see: https://github.com/grafana/diy-iot/blob/main/README.md#sending-metrics
#define GC_INFLUX_URL ""  // example: "influx-prod-58-prod-eu-central-0.grafana.net"
#define GC_USER ""
#define GC_PASS ""

// Set to 1 to show debug information on the LCD screen, or 0 to not display
#define LCD_SHOW_DEBUG_INFO "1"

// Plant name for this station -- used as Grafana label and on the LCD
#define PLANT_NAME "MyPlant"

// Normal watering duration (seconds) for regular plant tags
#define WATER_DURATION_SEC 5

// Golden ticket watering duration (seconds) -- the Willy Wonka special
#define GOLDEN_DURATION_SEC 5

// Golden ticket tag UIDs.
// Flash the sketch first, scan your special stickers, note the UIDs from Serial,
// then paste them here. Format: "04:AA:BB:CC:DD:EE:FF" (colon-separated hex).
// Set up to 3 golden tickets. Leave as "" to disable a slot.
#define GOLDEN_UID_1 ""
#define GOLDEN_UID_2 ""
#define GOLDEN_UID_3 ""

// MAC address of the Watering unit StickC Plus2.
// Default is broadcast (FF:FF:FF:FF:FF:FF) so it works out of the box.
// For dedicated pairing, replace with the actual MAC of your Watering device.
// The Watering unit prints its MAC on Serial at boot.
// Convert from Serial format  00:4B:12:C2:BE:EC
// to config format            {0x00, 0x4B, 0x12, 0xC2, 0xBE, 0xEC}
#define WATERING_MAC {0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF}
